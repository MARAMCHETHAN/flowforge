# Backend (put real values in backend/.env — gitignored — or your host's env settings)
GEMINI_API_KEY=            # https://aistudio.google.com/apikey (free tier)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ALLOWED_ORIGINS=http://localhost:3000   # comma-separated; add your Vercel URL in prod

# Frontend (Vercel → Project → Settings → Environment Variables)
REACT_APP_API_URL=http://localhost:8000  # your Render backend URL in prod
